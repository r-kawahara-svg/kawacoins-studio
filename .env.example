# =====================================================
# kawacoins-studio — 環境変数テンプレート
# .env.local にコピーして値を設定してください
# =====================================================

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# DB（Drizzle ORM 用。通常は Transaction Pooler 6543、drizzle-kit push 時は Session Pooler 5432）
DATABASE_URL=postgresql://postgres.xxxx:PASSWORD@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# 認証（このメールアドレスのみログインを許可）
ALLOWED_EMAIL=your@email.com

# 開発バイパス
# true: Magic Link なしで即ログイン扱い（NODE_ENV=development のときのみ有効）
# 本番 Vercel では NODE_ENV=production になるため、この値が true でも絶対に無効になる
# ローカル開発中のみ true にすること
DEV_AUTH_BYPASS=false

# Anthropic
ANTHROPIC_API_KEY=sk-ant-api03-...

# Unsplash（アイキャッチ背景写真。未設定の場合はグラデーション背景にフォールバック）
# https://unsplash.com/developers でアプリ登録 → Access Key を取得
UNSPLASH_ACCESS_KEY=your_unsplash_access_key

# WordPress（未設定の場合、WP 投稿をスキップして DB のみ更新）
WP_BASE_URL=https://yoursite.com
WP_USERNAME=your_wp_user
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
